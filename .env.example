# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full"

# Neon/Vercel prefixed fallback used by config/prisma helpers.
# Prefer DATABASE_URL locally unless your platform injects this name.
# dd_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full"

# Auth.js
AUTH_SECRET="replace-with-random-auth-secret"
AUTH_URL="https://localhost:3000"
NEXT_PUBLIC_APP_URL="https://localhost:3000"

# LinkedIn OAuth
AUTH_LINKEDIN_ID="replace-with-linkedin-client-id"
AUTH_LINKEDIN_SECRET="replace-with-linkedin-client-secret"

# Application encryption
# Must be a 64-character hex string (32 bytes).
ENCRYPTION_KEY="replace-with-64-character-hex-string"

# Email
RESEND_API_KEY="replace-with-resend-api-key"

# Sentry
SENTRY_DSN="https://PUBLIC_KEY@SENTRY_HOST/PROJECT_ID"
NEXT_PUBLIC_SENTRY_DSN="https://PUBLIC_KEY@SENTRY_HOST/PROJECT_ID"
SENTRY_AUTH_TOKEN="replace-with-sentry-auth-token"

# Stripe
STRIPE_SECRET_KEY="replace-with-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="replace-with-stripe-webhook-secret"
STRIPE_PRO_PRICE_ID="replace-with-stripe-pro-price-id"
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID="replace-with-stripe-pro-price-id"
STRIPE_GROWTH_PRICE_ID="replace-with-stripe-growth-price-id"
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID="replace-with-stripe-growth-price-id"
STRIPE_SEAT_PRICE_ID="replace-with-stripe-seat-price-id"
NEXT_PUBLIC_STRIPE_SEAT_PRICE_ID="replace-with-stripe-seat-price-id"

# Legacy/default Stripe upgrade price fallback.
NEXT_PUBLIC_STRIPE_PRICE_ID="replace-with-stripe-price-id"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="replace-with-vercel-blob-read-write-token"

# Vercel-provided URL fallbacks used in production deployments.
# These are usually injected by Vercel and do not need local values.
# VERCEL_PROJECT_PRODUCTION_URL="your-app.example.com"
# VERCEL_URL="your-preview-url.example.com"
